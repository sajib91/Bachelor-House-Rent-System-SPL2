NODE_ENV=development
BACKEND_PORT=5001
DATABASE_URL="postgresql://postgres:password@localhost:5432/to_let_globe?schema=public"
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_VERCEL_PREVIEWS=false

JWT_SECRET=your_super_strong_jwt_secret_here
JWT_EXPIRES_IN=1h

# --- Email Settings ---
# For Development (Ethereal.email)
ETHEREAL_HOST=smtp.ethereal.email
ETHEREAL_PORT=587
ETHEREAL_SECURE=false
ETHEREAL_USER= # Get from Ethereal or let script generate
ETHEREAL_PASS= # Get from Ethereal or let script generate

# For Production (Example)
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_SECURE=
# EMAIL_USER=
# EMAIL_PASS=
EMAIL_FROM_NAME="My App Name"
EMAIL_FROM_ADDRESS="noreply@example.com"

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SSLCommerz Payment Settings
# SSL_PAYMENT_MODE can be 'sandbox' or 'live'
SSL_PAYMENT_MODE=sandbox
SSL_STORE_ID=
SSL_STORE_PASSWORD=
# Public API base URL used in payment callbacks (required on hosted deployment)
PUBLIC_API_BASE_URL=http://localhost:5001
# Optional custom callback receiver URL for IPN
SSL_IPN_URL=

# If true, tenant manual payment endpoint is blocked and only SSLCommerz checkout is allowed
ENFORCE_SSL_TENANT_PAYMENTS=false